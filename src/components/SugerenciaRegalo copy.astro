---
// SugerenciaRegalos.astro
---

<section class="relative w-full overflow-hidden bg-[#0f2d50]">
    <!-- Flores decorativas top izquierda (opacidad baja para efecto sutil) -->
    <div class="absolute top-0 left-0 pointer-events-none z-0">
        <img
            src="/imagenes/florLateral.png"
            alt=""
            class="w-28 md:w-36 h-auto object-contain opacity-15"
        />
    </div>

    <!-- Flores decorativas top derecha -->
    <div class="absolute top-0 right-0 pointer-events-none z-0 scale-x-[-1]">
        <img
            src="/imagenes/florLateral.png"
            alt=""
            class="w-28 md:w-36 h-auto object-contain opacity-15"
        />
    </div>

    <!-- Contenido -->
    <div
        class="relative z-10 flex flex-col items-center text-center py-14 px-8 max-w-sm mx-auto"
    >
        <!-- Icono regalo -->
        <div id="sr-regalo" class="mb-5 opacity-0">
            <img
                src="/iconos/regalo.png"
                alt="Icono regalo"
                class="w-14 h-14 md:w-16 md:h-16 object-contain mx-auto blanco-filter"
            />
        </div>

        <!-- Título -->
        <div id="sr-titulo" class="mb-6 opacity-0">
            <h2
                class="font-[Dancing_Script] text-4xl md:text-5xl text-white leading-tight"
            >
                Sugerencia de Regalo
            </h2>
        </div>

        <!-- Texto -->
        <div id="sr-texto" class="mb-8 opacity-0">
            <p
                class="font-crimson text-sm md:text-base text-white/80 leading-relaxed mb-4"
            >
                Su presencia y sus buenos deseos son nuestro mejor regalo. Si
                desean hacernos llegar algún presente estaremos muy agradecidos.
            </p>
            <p
                class="font-crimson text-sm md:text-base text-white/70 italic tracking-wide"
            >
                Gracias por tu muestra de cariño
            </p>
        </div>

        <!-- Card sobre -->
        <div id="sr-card" class="w-full opacity-0">
            <div
                class="border border-white/25 rounded-2xl py-10 px-6 flex flex-col items-center gap-5 bg-white/5"
            >
                <!-- Icono sobre -->
                <img
                    src="/iconos/sobre.png"
                    alt="Icono sobre"
                    class="w-16 h-16 md:w-20 md:h-20 object-contain blanco-filter"
                />

                <!-- Texto card -->
                <div>
                    <p
                        class="font-crimson text-white text-base md:text-lg italic font-medium leading-snug"
                    >
                        Efectivo en sobres
                    </p>
                    <p class="font-crimson text-white/60 text-sm italic mt-1">
                        (Habrá un buzón)
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<link
    href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&display=swap"
    rel="stylesheet"
/>

<style>
    /* Convierte cualquier PNG a blanco puro */
    .blanco-filter {
        filter: brightness(0) invert(1);
        opacity: 0.9;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.set("#sr-regalo, #sr-titulo, #sr-texto, #sr-card", {
            opacity: 0,
            y: 30,
        });

        ScrollTrigger.create({
            trigger: "#sr-regalo",
            start: "top 88%",
            onEnter: () => {
                const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

                tl.to("#sr-regalo", { opacity: 1, y: 0, duration: 0.8 })
                    .to(
                        "#sr-titulo",
                        { opacity: 1, y: 0, duration: 0.9 },
                        "-=0.4",
                    )
                    .to(
                        "#sr-texto",
                        { opacity: 1, y: 0, duration: 0.9 },
                        "-=0.5",
                    )
                    .to(
                        "#sr-card",
                        {
                            opacity: 1,
                            y: 0,
                            duration: 1,
                            ease: "back.out(1.3)",
                        },
                        "-=0.4",
                    );
            },
            onLeaveBack: () => {
                gsap.to("#sr-regalo, #sr-titulo, #sr-texto, #sr-card", {
                    opacity: 0,
                    y: 30,
                    duration: 0.4,
                });
            },
        });
    });
</script>
