---
// FechaEvento.astro
---

<section class="py-2">
    <div class="max-w-2xl mx-auto text-center">
        <!-- Texto acompáñanos con palomas -->
        <div class="mb-6" id="texto-invitacion-container">
            <div
                class="flex items-center justify-center gap-6 sm:gap-6 md:gap-8 px-4"
            >
                <!-- Flor izquierda -->
                <div id="flor-izq" class="flex-shrink-0">
                    <img
                        src="/imagenes/florlateral.png"
                        alt="Flor decorativa"
                        class="w-16 h-auto md:w-24 object-contain opacity-85"
                    />
                </div>

                <!-- Texto central -->
                <div id="texto-invitacion" class="flex-shrink-0">
                    <p
                        class="font-[Dancing_Script] text-2xl sm:text-3xl md:text-4xl text-[#D4AF37] leading-relaxed text-center"
                    >
                        Acompáñanos este día<br />tan especial
                    </p>
                </div>

                <!-- Flor derecha (espejada) -->
                <div id="flor-der" class="flex-shrink-0 scale-x-[-1]">
                    <img
                        src="/imagenes/florlateral.png"
                        alt="Flor decorativa"
                        class="w-16 h-auto md:w-24 object-contain opacity-85"
                    />
                </div>
            </div>
        </div>

        <!-- Fecha -->
        <div class="relative max-w-md mx-auto" id="fecha-evento">
            <div class="flex items-center justify-center gap-4 md:gap-6">
                <!-- SÁBADO -->
                <div class="flex flex-col items-center w-24 md:w-28">
                    <div class="w-full h-px bg-[#c9a84c] mb-2"></div>
                    <span
                        class="font-crimson text-base md:text-lg text-[#1f4d7a] uppercase tracking-widest font-semibold text-center"
                    >
                        Sábado
                    </span>
                    <div class="w-full h-px bg-[#c9a84c] mt-2"></div>
                </div>

                <!-- Número 14 -->
                <div
                    class="flex items-center justify-center min-w-[80px] md:min-w-[100px]"
                >
                    <span
                        class="font-[Dancing_Script] text-5xl md:text-9xl text-[#1f4d7a] font-bold leading-none"
                    >
                        14
                    </span>
                </div>

                <!-- MARZO -->
                <div class="flex flex-col items-center w-24 md:w-28">
                    <div class="w-full h-px bg-[#c9a84c] mb-2"></div>
                    <span
                        class="font-crimson text-base md:text-lg text-[#1f4d7a] uppercase tracking-widest font-semibold text-center"
                    >
                        Marzo
                    </span>
                    <div class="w-full h-px bg-[#c9a84c] mt-2"></div>
                </div>
            </div>

            <!-- Año -->
            <div class="mt-2 flex justify-center" id="anio-evento">
                <p
                    class="font-crimson text-2xl md:text-4xl text-[#4a7a9b] font-semibold tracking-widest"
                >
                    2026
                </p>
            </div>

            <!-- Hora -->
            <div class="mt-4 flex justify-center" id="hora-evento">
                <div class="flex items-center gap-3">
                    <div
                        class="h-px w-10 bg-gradient-to-r from-transparent to-[#c9a84c]"
                    >
                    </div>
                    <p
                        class="font-crimson text-lg md:text-xl text-[#c9a84c] tracking-[0.25em] font-light"
                    >
                        14:00 hrs
                    </p>
                    <div
                        class="h-px w-10 bg-gradient-to-l from-transparent to-[#c9a84c]"
                    >
                    </div>
                </div>
            </div>
        </div>

        <!-- Separador SVG decorativo abajo -->
        <div class="flex justify-center mt-8" id="sep-abajo">
            <svg
                width="220"
                height="24"
                viewBox="0 0 220 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
            >
                <line
                    x1="0"
                    y1="12"
                    x2="88"
                    y2="12"
                    stroke="#a8c4dc"
                    stroke-width="1"></line>
                <circle cx="100" cy="12" r="3" fill="#c9a84c" opacity="0.8"
                ></circle>
                <circle cx="110" cy="12" r="5" fill="#c9a84c" opacity="0.9"
                ></circle>
                <circle cx="120" cy="12" r="3" fill="#c9a84c" opacity="0.8"
                ></circle>
                <line
                    x1="132"
                    y1="12"
                    x2="220"
                    y2="12"
                    stroke="#a8c4dc"
                    stroke-width="1"></line>
            </svg>
        </div>
    </div>
</section>

<link
    href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&display=swap"
    rel="stylesheet"
/>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            // Estado inicial — todo oculto
            gsap.set("#flor-izq", { opacity: 0, x: -60, scale: 0.8 });
            gsap.set("#flor-der", { opacity: 0, x: 60, scale: 0.8 });
            gsap.set("#texto-invitacion", { opacity: 0, y: 20, scale: 0.95 });
            gsap.set("#fecha-evento", { opacity: 0, y: 35, scale: 0.97 });
            gsap.set("#anio-evento", { opacity: 0, y: 15 });
            gsap.set("#hora-evento", { opacity: 0, y: 15 });
            gsap.set("#sep-abajo", { opacity: 0, scaleX: 0.2 });

            const tl = gsap.timeline({
                paused: true,
                defaults: { ease: "power3.out" },
            });

            tl
                // Flores entran desde los lados con un leve rebote
                .to(
                    "#flor-izq",
                    {
                        opacity: 1,
                        x: 0,
                        scale: 1,
                        duration: 1.1,
                        ease: "back.out(1.4)",
                    },
                    0,
                )
                .to(
                    "#flor-der",
                    {
                        opacity: 1,
                        x: 0,
                        scale: 1,
                        duration: 1.1,
                        ease: "back.out(1.4)",
                    },
                    0,
                )

                // Texto aparece desde abajo con fade suave
                .to(
                    "#texto-invitacion",
                    {
                        opacity: 1,
                        y: 0,
                        scale: 1,
                        duration: 1,
                        ease: "power2.out",
                    },
                    0.2,
                )

                // La fecha sube elegante
                .to(
                    "#fecha-evento",
                    { opacity: 1, y: 0, scale: 1, duration: 1.1 },
                    0.45,
                )

                // Año y hora aparecen suaves después
                .to("#anio-evento", { opacity: 1, y: 0, duration: 0.8 }, 0.75)
                .to("#hora-evento", { opacity: 1, y: 0, duration: 0.8 }, 0.9)

                // Separador se despliega al final
                .to(
                    "#sep-abajo",
                    {
                        opacity: 1,
                        scaleX: 1,
                        duration: 0.9,
                        ease: "power2.inOut",
                    },
                    1.05,
                )

                // Flores flotando infinito al terminar
                .call(() => {
                    gsap.to("#flor-izq", {
                        y: -7,
                        duration: 2.5,
                        ease: "sine.inOut",
                        yoyo: true,
                        repeat: -1,
                    });
                    gsap.to("#flor-der", {
                        y: -7,
                        duration: 2.8,
                        ease: "sine.inOut",
                        yoyo: true,
                        repeat: -1,
                        delay: 0.3,
                    });
                });

            // Dispara una sola vez al entrar al viewport
            ScrollTrigger.create({
                trigger: "#texto-invitacion-container",
                start: "top 85%",
                once: true,
                onEnter: () => tl.play(),
            });
        });
    }
</script>
