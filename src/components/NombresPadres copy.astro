---
// src/components/Padres.astro
const PADRE = "Rene Montaño Obando";
const MADRE = "Vania Rojas Perez";
const MADRINA_BAU = "Eleuteria Obando Blanco";
const MADRINA_PELO = "Kardinia Rojas Perez";
---

<section
    class="relative w-full flex flex-col items-center text-center py-8 px-6 overflow-visible"
>
    <!-- PADRES -->
    <div id="padres-titulo" class="mb-2 opacity-0">
        <p
            class="font-crimson text-xl md:text-sm font-normal text-[#D4AF37] uppercase"
        >
            Padres
        </p>
    </div>
    <div id="padres-nombres" class="mb-8 opacity-0 flex flex-col items-center">
        <p
            class="font-crimson text-lg md:text-xl font-normal text-[#3a5f80] tracking-widest"
        >
            {PADRE}
        </p>
        <p
            class="font-crimson text-lg md:text-xl font-normal text-[#3a5f80] tracking-widest"
        >
            {MADRE}
        </p>
    </div>

    <!-- Separador dorado -->
    <!-- <div id="sep-1" class="flex items-center gap-3 mb-8 opacity-0">
        <div
            class="h-px w-16 md:w-24 bg-gradient-to-r from-transparent to-[#c9a84c]"
        >
        </div>
        <svg
            width="10"
            height="10"
            viewBox="0 0 20 20"
            fill="#c9a84c"
            class="opacity-80 flex-shrink-0"
        >
            <path
                d="M10 2 L11.5 8 L18 8 L12.5 12 L14.5 18 L10 14 L5.5 18 L7.5 12 L2 8 L8.5 8 Z"
            ></path>
        </svg>
        <div
            class="h-px w-16 md:w-24 bg-gradient-to-l from-transparent to-[#c9a84c]"
        >
        </div>
    </div> -->

    <!-- MADRINA DE BAUTIZO -->
    <div id="madrina-bau-titulo" class="mb-2 opacity-0">
        <p
            class="font-crimson text-xl md:text-sm font-normal text-[#D4AF37] uppercase"
        >
            Madrina de Bautizo
        </p>
    </div>
    <div id="madrina-bau-nombre" class="mb-8 opacity-0">
        <p
            class="font-crimson text-xl md:text-xl font-normal text-[#3a5f80] tracking-widest"
        >
            {MADRINA_BAU}
        </p>
    </div>

    <!-- Separador dorado -->
    <!-- <div id="sep-2" class="flex items-center gap-3 mb-8 opacity-0">
        <div
            class="h-px w-16 md:w-24 bg-gradient-to-r from-transparent to-[#c9a84c]"
        >
        </div>
        <svg
            width="10"
            height="10"
            viewBox="0 0 20 20"
            fill="#c9a84c"
            class="opacity-80 flex-shrink-0"
        >
            <path
                d="M10 2 L11.5 8 L18 8 L12.5 12 L14.5 18 L10 14 L5.5 18 L7.5 12 L2 8 L8.5 8 Z"
            ></path>
        </svg>
        <div
            class="h-px w-16 md:w-24 bg-gradient-to-l from-transparent to-[#c9a84c]"
        >
        </div>
    </div> -->

    <!-- MADRINA DE CORTE DE PELO -->
    <div id="madrina-pelo-titulo" class="mb-2 opacity-0">
        <p
            class="font-crimson text-xl md:text-xl font-normal text-[#D4AF37] uppercase"
        >
            Madrina de Corte de Pelo
        </p>
    </div>
    <div id="madrina-pelo-nombre" class="mb-8 opacity-0">
        <p
            class="font-crimson text-lg md:text-xl font-normal text-[#3a5f80] tracking-widest"
        >
            {MADRINA_PELO}
        </p>
    </div>

    <!-- Separador dorado final -->
    <div id="sep-3" class="flex items-center gap-3 opacity-0">
        <div
            class="h-px w-16 md:w-24 bg-gradient-to-r from-transparent to-[#c9a84c]"
        >
        </div>
        <svg
            width="10"
            height="10"
            viewBox="0 0 20 20"
            fill="#c9a84c"
            class="opacity-80 flex-shrink-0"
        >
            <path
                d="M10 2 L11.5 8 L18 8 L12.5 12 L14.5 18 L10 14 L5.5 18 L7.5 12 L2 8 L8.5 8 Z"
            ></path>
        </svg>
        <div
            class="h-px w-16 md:w-24 bg-gradient-to-l from-transparent to-[#c9a84c]"
        >
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

        tl.fromTo(
            "#padres-titulo",
            { opacity: 0, y: -15 },
            { opacity: 1, y: 0, duration: 0.8 },
        )
            .fromTo(
                "#padres-nombres",
                { opacity: 0, y: 20 },
                { opacity: 1, y: 0, duration: 0.9 },
                "-=0.4",
            )
            .fromTo(
                "#sep-1",
                { opacity: 0, scaleX: 0.3 },
                { opacity: 1, scaleX: 1, duration: 0.7, ease: "power2.out" },
                "-=0.3",
            )
            .fromTo(
                "#madrina-bau-titulo",
                { opacity: 0, y: -15 },
                { opacity: 1, y: 0, duration: 0.8 },
                "-=0.2",
            )
            .fromTo(
                "#madrina-bau-nombre",
                { opacity: 0, y: 20 },
                { opacity: 1, y: 0, duration: 0.9 },
                "-=0.4",
            )
            .fromTo(
                "#sep-2",
                { opacity: 0, scaleX: 0.3 },
                { opacity: 1, scaleX: 1, duration: 0.7, ease: "power2.out" },
                "-=0.3",
            )
            .fromTo(
                "#madrina-pelo-titulo",
                { opacity: 0, y: -15 },
                { opacity: 1, y: 0, duration: 0.8 },
                "-=0.2",
            )
            .fromTo(
                "#madrina-pelo-nombre",
                { opacity: 0, y: 20 },
                { opacity: 1, y: 0, duration: 0.9 },
                "-=0.4",
            )
            .fromTo(
                "#sep-3",
                { opacity: 0, scaleX: 0.3 },
                { opacity: 1, scaleX: 1, duration: 0.7, ease: "power2.out" },
                "-=0.3",
            );
    });
</script>
