---
// RecepcionSocial.astro
---

<section class="relative w-full py-12 px-6">
    <!-- Hoja dorada izquierda -->
    <img
        src="/imagenes/hojadorada.png"
        alt="hoja dorada"
        class="absolute left-0 top-20 md:top-24 w-18 lg:w-28 h-18 lg:h-28 md:w-20 md:h-20 opacity-0 pointer-events-none z-10"
        id="rec-hoja-dorada-left"
    />

    <!-- Hoja dorada derecha -->
    <img
        src="/imagenes/hojadorada.png"
        alt="hoja dorada"
        class="absolute right-0 top-20 md:top-24 w-18 lg:w-28 h-18 lg:h-28 md:w-20 md:h-20 opacity-0 pointer-events-none z-10 scale-x-[-1]"
        id="rec-hoja-dorada-right"
    />

    <!-- Flor lateral izquierda -->
    <img
        src="/imagenes/florlateral.png"
        alt="hojas"
        class="absolute left-0 top-24 md:top-24 w-18 h-18 lg:w-28 lg:h-28 md:w-20 md:h-20 opacity-0 pointer-events-none z-[11]"
        id="rec-hoja-left"
    />

    <!-- Flor lateral derecha -->
    <img
        src="/imagenes/florlateral.png"
        alt="hojas"
        class="absolute right-0 top-24 md:top-24 w-18 lg:w-28 h-18 lg:h-28 md:w-20 md:h-20 opacity-0 pointer-events-none z-[11] scale-x-[-1]"
        id="rec-hoja-right"
    />

    <div class="max-w-md mx-auto" id="wrapper-recepcion">
        <div class="text-center opacity-0" id="recepcion-content">
            <!-- Título -->
            <h3
                class="font-crimson text-[#c9a84c] uppercase text-xl md:text-2xl font-semibold mb-6"
            >
                Recepción Social
            </h3>

            <!-- Icono Salón -->
            <div class="flex justify-center mb-6">
                <img
                    src="/iconos/recepcion.png"
                    alt="Icono Salón"
                    class="w-16 h-16 md:w-20 md:h-20 object-contain azul-filter-rec"
                    id="icono-salon"
                />
            </div>

            <!-- Separador dorado -->
            <div class="flex items-center gap-3 mb-5 justify-center">
                <div
                    class="h-px w-16 bg-gradient-to-r from-transparent to-[#c9a84c]"
                >
                </div>
                <svg
                    width="10"
                    height="10"
                    viewBox="0 0 20 20"
                    fill="#c9a84c"
                    class="opacity-80 flex-shrink-0"
                >
                    <path
                        d="M10 2 L11.5 8 L18 8 L12.5 12 L14.5 18 L10 14 L5.5 18 L7.5 12 L2 8 L8.5 8 Z"
                    ></path>
                </svg>
                <div
                    class="h-px w-16 bg-gradient-to-l from-transparent to-[#c9a84c]"
                >
                </div>
            </div>

            <!-- Nombre del Salón -->
            <p
                class="font-[Dancing_Script] text-[#1f4d7a] text-2xl md:text-3xl mb-3"
            >
                Salón de Eventos Sueños e Ilusiones
            </p>

            <!-- Dirección -->
            <p
                class="font-crimson text-[#4a7a9b] text-xl md:text-lg mb-6 tracking-wide"
            >
                Calle Victoria, detrás de la Clínica Saavedra
            </p>

            <!-- Hora y Botón -->
            <div class="flex items-center justify-center gap-3 relative">
                <!-- Recuadro de Hora -->
                <div
                    class="border border-[#a8c4dc] rounded px-6 py-2.5 bg-white/40"
                >
                    <p
                        class="font-crimson text-sm md:text-base text-[#1f4d7a] font-semibold tracking-widest"
                    >
                        15:00 HRS.
                    </p>
                </div>

                <!-- Botón Ubicación -->
                <div class="relative">
                    <a
                        href="https://maps.app.goo.gl/efAVyEwSTZCDF5LUA"
                        target="_blank"
                        class="bg-[#1f4d7a] hover:bg-[#3a6fa0] text-white px-6 py-2.5 rounded font-crimson text-sm md:text-base font-semibold transition-all duration-300 shadow-md hover:shadow-lg block tracking-wide"
                        id="rec-boton-ubicacion"
                    >
                        Ver ubicación
                    </a>

                    <!-- Mano pointer -->
                    <img
                        src="/imagenes/mano.png"
                        alt="Presionar aquí"
                        class="absolute -bottom-6 -right-6 md:-bottom-8 md:-right-8 w-10 h-10 md:w-12 md:h-12 object-contain opacity-0 pointer-events-none z-20"
                        id="rec-mano-pointer"
                    />
                </div>
            </div>
        </div>
    </div>

    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        const initRecepcion = () => {
            // Estado inicial
            gsap.set("#recepcion-content", { opacity: 0, y: 30 });
            gsap.set("#rec-hoja-left", { opacity: 0, x: -30 });
            gsap.set("#rec-hoja-right", { opacity: 0, x: 30 });
            gsap.set("#rec-hoja-dorada-left", { opacity: 0, x: -30 });
            gsap.set("#rec-hoja-dorada-right", { opacity: 0, x: 30 });
            gsap.set("#rec-mano-pointer", { opacity: 0, scale: 0.8 });

            const tl = gsap.timeline({ paused: true });

            tl.to(
                "#recepcion-content",
                { opacity: 1, y: 0, duration: 1.2, ease: "power3.out" },
                0,
            )
                .to(
                    "#rec-hoja-left",
                    { opacity: 0.8, x: 0, duration: 1.1, ease: "power2.out" },
                    0.3,
                )
                .to(
                    "#rec-hoja-right",
                    { opacity: 0.8, x: 0, duration: 1.1, ease: "power2.out" },
                    0.3,
                )
                .to(
                    "#rec-hoja-dorada-left",
                    { opacity: 0.9, x: 0, duration: 1.1, ease: "power2.out" },
                    0.6,
                )
                .to(
                    "#rec-hoja-dorada-right",
                    { opacity: 0.9, x: 0, duration: 1.1, ease: "power2.out" },
                    0.6,
                )
                .to(
                    "#rec-mano-pointer",
                    {
                        opacity: 1,
                        scale: 1,
                        duration: 0.5,
                        ease: "back.out(2)",
                    },
                    0.9,
                )
                .call(() => {
                    // Solo flotación vertical — sin rotación
                    gsap.to("#rec-hoja-left", {
                        y: -10,
                        duration: 3.5,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                    });
                    gsap.to("#rec-hoja-right", {
                        y: -8,
                        duration: 3.8,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 0.3,
                    });
                    gsap.to("#rec-hoja-dorada-left", {
                        y: -12,
                        duration: 4,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 0.5,
                    });
                    gsap.to("#rec-hoja-dorada-right", {
                        y: -11,
                        duration: 4.3,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut",
                        delay: 0.7,
                    });
                    gsap.to("#rec-mano-pointer", {
                        scale: 0.9,
                        duration: 0.6,
                        ease: "power1.inOut",
                        repeat: -1,
                        yoyo: true,
                        delay: 1,
                    });
                });

            // Una sola vez
            ScrollTrigger.create({
                trigger: "#wrapper-recepcion",
                start: "top 80%",
                once: true,
                onEnter: () => tl.play(),
            });
        };

        document.addEventListener("DOMContentLoaded", initRecepcion);
        document.addEventListener("astro:page-load", initRecepcion);
    </script>

    <style>
        .azul-filter-rec {
            filter: brightness(0) saturate(100%) invert(22%) sepia(60%)
                saturate(600%) hue-rotate(190deg) brightness(90%) contrast(95%);
        }
    </style>
</section>

<link
    href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&display=swap"
    rel="stylesheet"
/>
