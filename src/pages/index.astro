---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import Portada from "../components/Portada.astro";
import NombresFlores from "../components/NombresFlores.astro";

import Reproductor from "../components/Reproductor.astro";

import SugerenciaRegalo from "../components/SugerenciaRegalo.astro";
import DedicatoriaNombres from "../components/DedicatoriaNombres.astro";
import Fecha from "../components/Fecha.astro";

import NombresPadres from "../components/NombresPadres.astro";
import Contador from "../components/Contador.astro";
import DireccionReligiosa from "../components/DireccionReligiosa.astro";
import DireccionRecepcion from "../components/DireccionRecepcion.astro";
import Itinerario from "../components/Itinerario.astro";
import Foto from "../components/Foto.astro";
import Confirmar from "../components/Confirmar.astro";
---

<Layout title="Boda">
    <!-- PORTADA (se muestra primero, bloquea scroll) -->
    <Portada />

    <!-- CONTENIDO PRINCIPAL (oculto hasta que se presione el sobre) -->
    <div id="contenido-principal">
        <NombresFlores />
        <DedicatoriaNombres />
        <NombresPadres />
        <Fecha />
        <Contador />
        <DireccionReligiosa />
        <DireccionRecepcion />
        <Itinerario />
        <Foto />
        <!-- <SugerenciaRegalo /> -->
        <Confirmar />
    </div>
</Layout>
